# ── PostgreSQL (Render에서 DB 연결 시 Internal Database URL 사용) ──
DATABASE_URL=postgresql://user:password@host:5432/fridgedb

# ── CORS (프론트엔드 주소, 여러 개면 콤마로) ──
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5500

# ── Gemini API 키 (Google AI Studio에서 발급) ──
GEMINI_KEY_SCAN=AIza...
GEMINI_KEY_RECIPE=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI (선택) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL_SCAN=gpt-4o
OPENAI_MODEL_RECIPE=gpt-4o-mini

# ── 식품안전나라 바코드 API (선택) ──
FOOD_SAFETY_API_KEY=
